RewriteEngine On

# Global
RewriteRule ^admin$ admin.php
RewriteRule ^home$ index.php
RewriteRule ^login$ login.php
RewriteRule ^logout$ controller/user/UserMainController.php?logout=1


#--------------------- view ---------------------

# Projet / Service
RewriteRule ^listeProjetService$ view/pages/admin/projetService/liste.php

# Competence
RewriteRule ^listeCompetence$ view/pages/admin/competence/liste.php

# User
RewriteRule ^listeUser$ view/pages/admin/user/liste.php

#Contact
RewriteRule ^listeContact$ view/pages/admin/contact/liste.php

#--------------------- Controller ---------------------
RewriteRule ^contactMainController$ controller/contact/ContactMainController.php
RewriteRule ^projetServiceMainController$ controller/projetService/ProjetServiceMainController.php [L,QSA]
RewriteRule ^userMainController$ controller/user/userMainController.php
RewriteRule ^competenceMainController$ controller/user/CompetenceMainController.php

#--------------------- Model ---------------------
RewriteRule ^userRepo$ model/UserRepository.php
RewriteRule ^projetServiceRepo$ model/ProjetServiceRepository.php
RewriteRule ^contactRepo$ model/ContactRepository.php
RewriteRule ^competenceRepo$ model/CompetenceRepository.php